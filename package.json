{
  "name": "brownie-to-ape",
  "version": "0.7.8",
  "description": "Automated migration codemod from Brownie to ApeWorx Ape — 17-pass jssg transform, 250 tests (90 fixture + 125 Vitest + 35 pytest incl. Hypothesis fuzzer), zero false positives across 5 OSS repos incl. Yearn Finance.",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npx codemod@latest jssg test -l python ./scripts/codemod.ts ./tests/fixtures",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:property": "vitest run tests/property",
    "test:qa": "vitest run tests/qa",
    "test:python": "python -m pytest tests/ -v",
    "test:all": "npm test && npm run test:unit && npm run test:python",
    "validate": "npx codemod@latest workflow validate -w workflow.yaml",
    "benchmark": "bash scripts/benchmark.sh",
    "demo": "bash demo/run-demo.sh",
    "render-cast": "python scripts/render_cast.py",
    "publish:codemod": "npx codemod@latest publish"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  },
  "keywords": [
    "brownie",
    "ape",
    "apeworx",
    "codemod",
    "migration",
    "python",
    "ethereum",
    "smart-contracts"
  ],
  "license": "MIT",
  "author": "Pugar Huda Mantoro <pugarhudam@gmail.com>",
  "homepage": "https://github.com/PugarHuda/brownie-to-ape",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PugarHuda/brownie-to-ape.git"
  },
  "bugs": {
    "url": "https://github.com/PugarHuda/brownie-to-ape/issues"
  }
}
